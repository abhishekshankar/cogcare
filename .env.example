# --- Browser-safe Vite vars (email flows) ---
# Optional: HTTPS URL for the Amplify completeAssessment Lambda (onboarding + report email).
# If unset, the app uses custom.completeAssessmentFunctionUrl from src/amplify_outputs.json.
VITE_COMPLETE_ASSESSMENT_URL=

# Optional override: legacy “report only” API. If unset in dev, the app uses same-origin /api/send-quiz-email (Vite dev server).
# Production: set to your deployed URL, e.g. https://your-host.com/api/send-quiz-email
VITE_QUIZ_EMAIL_API_URL=

# --- Local dev: real email sends (loaded by Vite for api/send-quiz-email.js; never exposed to the client) ---
# Copy this file to .env and fill in. Brevo: https://app.brevo.com/settings/keys/api
MAIL_PROVIDER=brevo
BREVO_API_KEY=
BREVO_SENDER_EMAIL=
# BREVO_SENDER_NAME=CogCare
# If API returns "unrecognised IP", add your public IPv4 in Brevo only (not in this file):
# https://app.brevo.com/security/authorised_ips

# Amazon SES alternative (set MAIL_PROVIDER=ses):
# AWS_REGION=us-east-1
# SES_FROM_EMAIL=
# SES_FROM_NAME=CogCare
# On non-AWS hosts: AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY with ses:SendEmail

# Optional CORS for the local email route
# ALLOWED_ORIGIN=http://localhost:5173

# --- Cursor: Brevo MCP (not read from this file) ---
# Set ~/.cursor/mcp.json → mcpServers.brevo.env.BREVO_MCP_AUTH to "Bearer <your-mcp-token>".
# Create an API key at https://app.brevo.com/settings/keys/api with the MCP option enabled.
# See https://developers.brevo.com/docs/mcp-protocol
